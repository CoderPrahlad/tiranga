<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.qrcode/1.0/jquery.qrcode.min.js"></script>

<script>
    // Dynamic UPI ID population
  const upiId = "<%= UpiId %>";
    document.getElementById('upi_display').textContent = upiId;

    // QR Code generation
    $(document).ready(function() {
        $("#qrcode").qrcode({
            text: `upi://pay?pa=${upiId}&pn=YourName&am=<%=Amount%>&cu=INR`,
            width: 256,
            height: 256
        });
    });

    // Copy UPI ID
    document.getElementById("copy_upi_id").addEventListener("click", () => {
        navigator.clipboard.writeText(upiId).then(() => alert("UPI ID copied to clipboard! 📋"));
    });

    // Form submission
    document.getElementById("submit_button").addEventListener("click", async (event) => {
        event.preventDefault();
        const upiRefNo = document.getElementById("upi_ref_no").value;
        const amount = "<%=Amount%>";

        if (!upiRefNo) {
            alert("Please enter a UPI reference number.");
            return;
        }

        try {
            const response = await axios.post("/wallet/paynow/manual_upi_request", { money: amount, utr: upiRefNo });

            if (!response?.data || response?.data?.status === false) {
                alert(response?.data?.message || "Something went wrong!");
                return;
            }

            alert(response.data.message);
            window.location.href = "/wallet/rechargerecord";
        } catch (error) {
            console.error("Error:", error);
            alert("Something went wrong!");
        }
    });

    // App link handler
    function openApp(app) {
        let appUrl;
        switch (app) {
            case 'paytm': appUrl = 'upi://pay?pa=niko37602-1@okaxis&amp;cu=INR&amp;am=<%=Amount%>'; break;
            case 'phonepe': appUrl = 'upi://pay?pa=niko37602-1@okaxis&amp;cu=INR&amp;am=<%=Amount%>'; break;
            case 'gpay': appUrl = 'upi://pay?pa=niko37602-1@okaxis&amp;cu=INR&amp;am=<%=Amount%>'; break;
            default: alert('App not recognized'); return;
        }
        window.open(appUrl, '_blank');
    }
</script>
